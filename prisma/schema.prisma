generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider          = "postgresql"
  url               = env("POSTGRES_PRISMA_URL")
  directUrl         = env("POSTGRES_URL_NON_POOLING")
  shadowDatabaseUrl = env("POSTGRES_URL_NON_POOLING")
}

model User {
  id             Int             @id @default(autoincrement())
  username       String          @unique @db.VarChar(255)
  email          String          @unique @db.VarChar(255)
  passwordHash   String
  reps           Set[]
  workoutFolders WorkoutFolder[]
}

model WorkoutFolder {
  id         Int              @id @default(autoincrement())
  folderName String           @db.VarChar(30)
  userId     Int
  exercises  FolderExercise[]
  user       User             @relation(fields: [userId], references: [id])
}

model Exercise {
  id   Int    @id @default(autoincrement())
  name String
}

model Set {
  weight    Float
  reps      Int
  userId    Int
  exercise  String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id])

  @@id([userId, createdAt])
}

model FolderExercise {
  exercise      String
  folderId      Int
  workoutFolder WorkoutFolder @relation(fields: [folderId], references: [id], onDelete: Cascade)

  @@id([exercise, folderId])
}
